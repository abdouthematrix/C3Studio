<UserControl
    x:Class="C3Studio.Views.Pages.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:C3Studio.Core.Models"
    xmlns:vm="clr-namespace:C3Studio.ViewModels"
    x:Name="RootControl"
    d:DataContext="{d:DesignInstance vm:WorkspaceViewModel}"
    Background="{StaticResource Br.BgDeep}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <!--  Gives ContextMenu access to the page DataContext (outside visual tree)  -->
        <FrameworkElement x:Key="VmProxy" DataContext="{Binding DataContext, Source={x:Reference RootControl}}" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <!--  toolbar  -->
            <RowDefinition Height="*" />
            <!--  main content  -->
            <RowDefinition Height="28" />
            <!--  status bar  -->
        </Grid.RowDefinitions>

        <!--
            ══════════════════════════════════════════════════════════════
            TOOLBAR
            ═══════════════════════════════════════════════════════════════
        -->
        <Border
            Grid.Row="0"
            Background="{StaticResource Br.BgCard}"
            BorderBrush="{StaticResource Br.Border}"
            BorderThickness="0,0,0,1">

            <StackPanel Orientation="Vertical">

                <!--  ── Row 1 : Paths ───────────────────────────────────────────  -->
                <Border BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1">
                    <StackPanel
                        Margin="12,6"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Padding="10,5"
                            Command="{Binding GoToSetupCommand}"
                            Content="⚙  Setup"
                            Style="{StaticResource GhostButton}"
                            ToolTip="Change game path and settings" />
                    </StackPanel>
                </Border>
                <Border BorderBrush="{StaticResource Br.Border}" BorderThickness="0,0,0,1">
                    <StackPanel
                        Margin="12,6"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <!--  Model  -->
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SectionLabel}"
                            Text="Model" />
                        <TextBox
                            Width="240"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource PathBox}"
                            Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Command="{Binding BrowseFileCommand}"
                            Content="📂"
                            Style="{StaticResource PrimaryButton}" />
                        <Button
                            Margin="0,0,16,0"
                            Padding="10,5"
                            Command="{Binding LoadModelCommand}"
                            Content="Load"
                            Style="{StaticResource PrimaryButton}" />

                        <Rectangle
                            Width="1"
                            Height="20"
                            Margin="0,0,16,0"
                            Fill="{StaticResource Br.Border}" />

                        <!--  Texture  -->
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SectionLabel}"
                            Text="Texture" />
                        <TextBox
                            Width="220"
                            Margin="0,0,16,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource PathBox}"
                            Text="{Binding TexturePath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Command="{Binding BrowseTextureCommand}"
                            Content="📂"
                            Style="{StaticResource GhostButton}" />
                        <Rectangle
                            Width="1"
                            Height="20"
                            Margin="0,0,16,0"
                            Fill="{StaticResource Br.Border}" />

                        <!--  Motion  -->
                        <TextBlock
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource SectionLabel}"
                            Text="Motion" />
                        <TextBox
                            Width="220"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Style="{StaticResource PathBox}"
                            Text="{Binding MotionPath, UpdateSourceTrigger=PropertyChanged}" />
                        <Button
                            Margin="0,0,6,0"
                            Padding="10,5"
                            Command="{Binding BrowseMotionCommand}"
                            Content="📂"
                            Style="{StaticResource GhostButton}" />
                        <Button
                            Padding="10,5"
                            Command="{Binding ApplyMotionCommand}"
                            Content="▶  Apply"
                            Style="{StaticResource GhostButton}" />

                        <Rectangle
                            Width="1"
                            Height="20"
                            Margin="0,0,16,0"
                            Fill="{StaticResource Br.Border}" />
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SectionLabel}"
                                    Text="Asb" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    Foreground="{StaticResource Br.Gold}"
                                    Text="{Binding Asb, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Slider
                                Width="50"
                                Foreground="{StaticResource Br.Gold}"
                                IsSnapToTickEnabled="False"
                                Maximum="13"
                                Minimum="1"
                                TickFrequency="1"
                                Value="{Binding Asb, Mode=TwoWay}" />
                        </StackPanel>
                        <Rectangle
                            Width="1"
                            Height="20"
                            Margin="0,0,16,0"
                            Fill="{StaticResource Br.Border}" />
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource SectionLabel}"
                                    Text="Adb" />
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    FontFamily="Consolas"
                                    FontSize="13"
                                    Foreground="{StaticResource Br.Gold}"
                                    Text="{Binding Adb, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Slider
                                Width="50"
                                Foreground="{StaticResource Br.Gold}"
                                IsSnapToTickEnabled="False"
                                Maximum="13"
                                Minimum="1"
                                TickFrequency="1"
                                Value="{Binding Adb, Mode=TwoWay}" />
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!--
            ══════════════════════════════════════════════════════════════
            MAIN CONTENT  =  asset browser | viewport | properties
            ═══════════════════════════════════════════════════════════════
        -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    Width="220"
                    MinWidth="160"
                    MaxWidth="400" />
                <ColumnDefinition Width="4" />
                <!--  splitter  -->
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="4" />
                <!--  splitter  -->
                <ColumnDefinition
                    Width="230"
                    MinWidth="180"
                    MaxWidth="360" />
            </Grid.ColumnDefinitions>

            <!--  ── ASSET BROWSER ────────────────────────────────────────────  -->
            <Border
                Grid.Column="0"
                Background="{StaticResource Br.BgSurface}"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Browser header  -->
                    <Border
                        Grid.Row="0"
                        Background="{StaticResource Br.BgCard}"
                        BorderBrush="{StaticResource Br.Border}"
                        BorderThickness="0,0,0,1">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                Style="{StaticResource SectionLabel}"
                                Text="ASSETS" />
                            <!--  Search  -->
                            <Grid Grid.Column="1" Margin="10,0">
                                <TextBox
                                    Padding="30,7,28,7"
                                    Style="{StaticResource SearchBox}"
                                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock
                                    Margin="9,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="{StaticResource Br.TextDim}"
                                    IsHitTestVisible="False"
                                    Text="🔍" />
                                <Button
                                    Margin="0,0,5,0"
                                    Padding="5,1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Command="{Binding ClearSearchCommand}"
                                    Content="✕"
                                    FontSize="10"
                                    Style="{StaticResource IconButton}"
                                    Visibility="{Binding SearchText, Converter={StaticResource NullOrEmptyToVis}}" />
                            </Grid>
                            <!--<Button
                                Width="24"
                                Height="24"
                                Padding="0"
                                HorizontalAlignment="Right"
                                Command="{Binding RefreshTreeCommand}"
                                Content="↺"
                                FontSize="14"
                                Style="{StaticResource GhostButton}"
                                ToolTip="Refresh asset tree" />-->
                        </Grid>
                    </Border>

                    <!--  Tree  -->
                    <TreeView
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding FilteredAssetTree}"
                        SelectedItemChanged="AssetTree_SelectedItemChanged">

                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{StaticResource Br.TextPrimary}" />
                                <Setter Property="FontFamily" Value="Segoe UI" />
                                <Setter Property="FontSize" Value="12" />
                                <Setter Property="Padding" Value="4,3" />
                                <Setter Property="IsExpanded" Value="False" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Br.BgElevated}" />
                                        <Setter Property="Foreground" Value="{StaticResource Br.Gold}" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Br.BgElevated}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.Resources>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:AssetNode}" ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Text="{Binding Icon}" />
                                    <TextBlock VerticalAlignment="Center" Text="{Binding Label}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Br.TextPrimary}" />
                                                <Setter Property="FontSize" Value="12" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadable}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Br.TextPrimary}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsLoadable}" Value="False">
                                                        <Setter Property="Foreground" Value="{StaticResource Br.Gold}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter Property="FontSize" Value="11" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Command="{Binding Source={StaticResource VmProxy}, Path=DataContext.ExportNodeCommand}" Header="⬇ Export asset…" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                </Grid>
            </Border>

            <!--  ── SPLITTER ────────────────────────────────────────────────  -->
            <GridSplitter
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Stretch"
                Background="{StaticResource Br.Border}"
                ShowsPreview="False" />

            <!--  ── MONOGAME VIEWPORT ────────────────────────────────────────  -->
            <Border Grid.Column="2" Background="#0B0B14">
                <!--  C3StudioGame is added here programmatically in code-behind  -->
                <Grid x:Name="ViewportHost">
                    <!--  Fallback shown before the MonoGame control is attached  -->
                    <StackPanel
                        x:Name="ViewportPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="0.3">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="64"
                            Foreground="{StaticResource Br.Gold}"
                            Text="⚔" />
                        <TextBlock
                            Margin="0,12,0,0"
                            HorizontalAlignment="Center"
                            Style="{StaticResource SubTitle}"
                            Text="MonoGame Viewport" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource SectionLabel}"
                            Text="Initialising…" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  ── SPLITTER ────────────────────────────────────────────────  -->
            <GridSplitter
                Grid.Column="3"
                Width="4"
                HorizontalAlignment="Stretch"
                Background="{StaticResource Br.Border}"
                ShowsPreview="False" />

            <!--  ── PROPERTIES PANEL ─────────────────────────────────────────  -->
            <Border
                Grid.Column="4"
                Background="{StaticResource Br.BgSurface}"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="1,0,0,0">
                <ScrollViewer Padding="14" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!--  Motions section  -->
                        <TextBlock
                            Margin="4,12,4,4"
                            Style="{StaticResource SectionLabel}"
                            Text="MOTIONS" />

                        <ListBox
                            MaxHeight="180"
                            ItemsSource="{Binding AvailableMotions}"
                            SelectedItem="{Binding SelectedMotion, Mode=TwoWay}"
                            Style="{StaticResource NpcListBox}"
                            Visibility="{Binding AvailableMotions.Count, Converter={StaticResource ZeroToCollapsed}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <Border Style="{StaticResource MotionChip}">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource Br.Gold}"
                                                Text="{Binding Label}" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!--  Section: Playback  -->
                        <TextBlock
                            Margin="0,0,0,10"
                            Style="{StaticResource SectionLabel}"
                            Text="PLAYBACK" />

                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                            <!--  Step back  -->
                            <Button
                                Width="32"
                                Padding="0"
                                Command="{Binding StepBackCommand}"
                                Content="◀"
                                FontSize="14"
                                Style="{StaticResource GhostButton}"
                                ToolTip="Previous frame" />

                            <!--  Play / Pause  -->
                            <Button
                                Width="36"
                                Margin="4,0"
                                Padding="0"
                                Command="{Binding PlayPauseCommand}"
                                Content="{Binding PlayPauseLabel}"
                                FontSize="16"
                                Style="{StaticResource PrimaryButton}"
                                ToolTip="Play / Pause  (Space)" />

                            <!--  Step fwd  -->
                            <Button
                                Width="32"
                                Padding="0"
                                Command="{Binding StepFwdCommand}"
                                Content="▶"
                                FontSize="14"
                                Style="{StaticResource GhostButton}"
                                ToolTip="Next frame" />
                        </StackPanel>

                        <!--  Frame info card  -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="14,10"
                            Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionLabel}" Text="Frame" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Consolas"
                                    FontSize="22"
                                    Foreground="{StaticResource Br.Gold}"
                                    Text="{Binding FrameLabel}" />
                            </StackPanel>
                        </Border>

                        <!--  FPS card  -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="14,10"
                            Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        Style="{StaticResource SectionLabel}"
                                        Text="FPS" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="13"
                                        Foreground="{StaticResource Br.Gold}"
                                        Text="{Binding Fps, StringFormat={}{0:0}}" />
                                </Grid>
                                <Slider
                                    Foreground="{StaticResource Br.Gold}"
                                    IsSnapToTickEnabled="False"
                                    Maximum="60"
                                    Minimum="1"
                                    TickFrequency="5"
                                    Value="{Binding Fps, Mode=TwoWay}" />
                                <StackPanel
                                    Margin="0,6,0,0"
                                    HorizontalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Button
                                        Margin="0,0,4,0"
                                        Padding="8,3"
                                        Command="{Binding SetFpsCommand}"
                                        CommandParameter="15"
                                        Content="15"
                                        FontSize="11"
                                        Style="{StaticResource GhostButton}" />
                                    <Button
                                        Margin="0,0,4,0"
                                        Padding="8,3"
                                        Command="{Binding SetFpsCommand}"
                                        CommandParameter="24"
                                        Content="24"
                                        FontSize="11"
                                        Style="{StaticResource GhostButton}" />
                                    <Button
                                        Padding="8,3"
                                        Command="{Binding SetFpsCommand}"
                                        CommandParameter="30"
                                        Content="30"
                                        FontSize="11"
                                        Style="{StaticResource GhostButton}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!--  Section: Camera  -->
                        <TextBlock
                            Margin="0,8,0,10"
                            Style="{StaticResource SectionLabel}"
                            Text="CAMERA" />

                        <Border
                            Margin="0,0,0,12"
                            Padding="14,10"
                            Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Style="{StaticResource SectionLabel}"
                                    Text="Left-drag: orbit" />
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Style="{StaticResource SectionLabel}"
                                    Text="Scroll / W S: zoom" />
                                <Button
                                    Padding="10,6"
                                    Command="{Binding ResetCameraCommand}"
                                    Content="Reset Camera"
                                    Style="{StaticResource GhostButton}" />
                            </StackPanel>
                        </Border>

                        <!--  Section: File  -->
                        <TextBlock
                            Margin="0,8,0,10"
                            Style="{StaticResource SectionLabel}"
                            Text="FILE" />

                        <Border Padding="14,10" Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Style="{StaticResource SectionLabel}"
                                    Text="Path" />
                                <TextBlock
                                    FontFamily="Consolas"
                                    FontSize="10"
                                    Foreground="{StaticResource Br.TextDim}"
                                    Text="{Binding ModelPath}"
                                    TextWrapping="Wrap"
                                    ToolTip="{Binding ModelPath}" />
                            </StackPanel>
                        </Border>

                        <!--  Section: Export  -->
                        <TextBlock
                            Margin="0,8,0,10"
                            Style="{StaticResource SectionLabel}"
                            Text="EXPORT" />

                        <Border Padding="14,12" Style="{StaticResource Card}">
                            <StackPanel>

                                <!--  Layout  -->
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Style="{StaticResource SectionLabel}"
                                    Text="Folder layout" />
                                <ComboBox
                                    Margin="0,0,0,10"
                                    ItemsSource="{Binding Source={StaticResource ExportLayoutValues}}"
                                    SelectedItem="{Binding ExportLayout, Mode=TwoWay}"
                                    Style="{StaticResource DarkComboBox}"
                                    ToolTip="How output files are arranged inside the chosen folder" />

                                <!--  Conflict  -->
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Style="{StaticResource SectionLabel}"
                                    Text="If file exists" />
                                <ComboBox
                                    Margin="0,0,0,10"
                                    ItemsSource="{Binding Source={StaticResource ExportConflictValues}}"
                                    SelectedItem="{Binding ExportConflictMode, Mode=TwoWay}"
                                    Style="{StaticResource DarkComboBox}" />

                                <!--  Include motions toggle  -->
                                <CheckBox
                                    Margin="0,0,0,12"
                                    Content="Include motions"
                                    Foreground="{StaticResource Br.TextPrimary}"
                                    IsChecked="{Binding ExportMotions, Mode=TwoWay}" />

                                <!--  Export / Cancel buttons  -->
                                <Grid>
                                    <Button
                                        Padding="10,7"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding ExportNodeCommand}"
                                        Content="⬇  Export asset…"
                                        Style="{StaticResource PrimaryButton}"
                                        Visibility="{Binding IsExporting, Converter={StaticResource InvBoolToVis}}" />
                                    <Button
                                        Padding="10,7"
                                        HorizontalAlignment="Stretch"
                                        Click="CancelExport_Click"
                                        Content="✕  Cancel"
                                        Style="{StaticResource GhostButton}"
                                        Visibility="{Binding IsExporting, Converter={StaticResource BoolToVis}}" />
                                </Grid>

                                <!--  Status text  -->
                                <TextBlock
                                    Margin="0,8,0,0"
                                    FontFamily="Consolas"
                                    FontSize="10"
                                    Foreground="{StaticResource Br.TextDim}"
                                    Text="{Binding ExportStatus}"
                                    TextWrapping="Wrap" />

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!--
            ══════════════════════════════════════════════════════════════
            STATUS BAR
            ═══════════════════════════════════════════════════════════════
        -->
        <Border
            Grid.Row="2"
            Padding="12,0"
            Background="{StaticResource Br.BgCard}"
            BorderBrush="{StaticResource Br.Border}"
            BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource Br.TextSecond}"
                    Text="{Binding StatusMessage}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource Br.TextDim}"
                    Text="C3Studio · Phase 2" />
            </Grid>
        </Border>

    </Grid>
</UserControl>
