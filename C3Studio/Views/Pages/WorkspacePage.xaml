<UserControl
    x:Class="C3Studio.Views.Pages.WorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:C3Studio.ViewModels"
    xmlns:models="clr-namespace:C3Studio.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance vm:WorkspaceViewModel}"
    Background="{StaticResource Br.BgDeep}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>   <!-- toolbar -->
            <RowDefinition Height="*"/>    <!-- main content -->
            <RowDefinition Height="28"/>   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             TOOLBAR
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource Br.BgCard}"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">

                <!-- Browse file -->
                <Button Content="📂  Open File"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding BrowseFileCommand}"
                        Padding="14,6" Margin="0,0,8,0"/>

                <!-- Path display -->
                <TextBox Style="{StaticResource PathBox}"
                         Text="{Binding ModelPath, UpdateSourceTrigger=PropertyChanged}"
                         Width="320" VerticalAlignment="Center" Margin="0,0,8,0"/>

                <!-- Load -->
                <Button Content="Load"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadModelCommand}"
                        Padding="14,6" Margin="0,0,16,0"/>

                <!-- Separator -->
                <Rectangle Width="1" Height="22" Fill="{StaticResource Br.Border}" Margin="0,0,16,0"/>

                <!-- Reset Camera -->
                <Button Content="🎥  Reset"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding ResetCameraCommand}"
                        Padding="10,6" Margin="0,0,4,0"
                        ToolTip="Reset camera to default orbit"/>

                <!-- Separator -->
                <Rectangle Width="1" Height="22" Fill="{StaticResource Br.Border}" Margin="4,0,8,0"/>

                <!-- Step back -->
                <Button Content="◀"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding StepBackCommand}"
                        Width="32" Padding="0" FontSize="14"
                        ToolTip="Previous frame"/>

                <!-- Play / Pause -->
                <Button Content="{Binding PlayPauseLabel}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding PlayPauseCommand}"
                        Width="36" Padding="0" FontSize="16" Margin="4,0"
                        ToolTip="Play / Pause  (Space)"/>

                <!-- Step fwd -->
                <Button Content="▶"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding StepFwdCommand}"
                        Width="32" Padding="0" FontSize="14"
                        ToolTip="Next frame"/>

                <!-- Frame label -->
                <TextBlock Text="{Binding FrameLabel}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{StaticResource Br.TextSecond}"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           MinWidth="70"/>

                <!-- Separator -->
                <Rectangle Width="1" Height="22" Fill="{StaticResource Br.Border}" Margin="8,0"/>

                <!-- FPS label -->
                <TextBlock Text="FPS"
                           Style="{StaticResource SectionLabel}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>

                <!-- FPS slider -->
                <Slider Minimum="1" Maximum="60"
                        Value="{Binding Fps, Mode=TwoWay}"
                        Width="80" VerticalAlignment="Center"
                        TickFrequency="5" IsSnapToTickEnabled="False"
                        Foreground="{StaticResource Br.Gold}"/>

                <!-- FPS value -->
                <TextBlock Text="{Binding Fps, StringFormat={}{0:0}}"
                           FontFamily="Consolas" FontSize="12"
                           Foreground="{StaticResource Br.TextSecond}"
                           VerticalAlignment="Center" Margin="6,0,0,0"
                           MinWidth="26"/>

                <!-- Loading spinner -->
                <TextBlock Text="⟳  Loading…"
                           FontSize="12" Margin="16,0,0,0"
                           Foreground="{StaticResource Br.Gold}"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             MAIN CONTENT  =  asset browser | viewport | properties
        ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" MaxWidth="400"/>
                <ColumnDefinition Width="4"/>        <!-- splitter -->
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>        <!-- splitter -->
                <ColumnDefinition Width="230" MinWidth="180" MaxWidth="360"/>
            </Grid.ColumnDefinitions>

            <!-- ── ASSET BROWSER ──────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    Background="{StaticResource Br.BgSurface}"
                    BorderBrush="{StaticResource Br.Border}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Browser header -->
                    <Border Grid.Row="0"
                            Background="{StaticResource Br.BgCard}"
                            BorderBrush="{StaticResource Br.Border}"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="10,0">
                            <TextBlock Text="ASSETS"
                                       Style="{StaticResource SectionLabel}"
                                       VerticalAlignment="Center"/>
                            <Button Content="↺"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding RefreshTreeCommand}"
                                    Width="24" Height="24" Padding="0"
                                    FontSize="14"
                                    ToolTip="Refresh asset tree"/>
                        </Grid>
                    </Border>

                    <!-- Tree -->
                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding AssetTree}"
                              Background="Transparent"
                              BorderThickness="0"
                              SelectedItemChanged="AssetTree_SelectedItemChanged">

                        <TreeView.Resources>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="Background"   Value="Transparent"/>
                                <Setter Property="Foreground"   Value="{StaticResource Br.TextPrimary}"/>
                                <Setter Property="FontFamily"   Value="Segoe UI"/>
                                <Setter Property="FontSize"     Value="12"/>
                                <Setter Property="Padding"      Value="4,3"/>
                                <Setter Property="IsExpanded"   Value="False"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Br.BgElevated}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Br.Gold}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Br.BgElevated}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.Resources>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type models:AssetNode}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="12" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Label}"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Br.TextPrimary}"/>
                                                <Setter Property="FontSize"   Value="12"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLoadable}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource Br.TextPrimary}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsLoadable}" Value="False">
                                                        <Setter Property="Foreground" Value="{StaticResource Br.Gold}"/>
                                                        <Setter Property="FontWeight"  Value="SemiBold"/>
                                                        <Setter Property="FontSize"    Value="11"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>

                </Grid>
            </Border>

            <!-- ── SPLITTER ──────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="1"
                          Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Br.Border}"
                          ShowsPreview="False"/>

            <!-- ── MONOGAME VIEWPORT ──────────────────────────────────────── -->
            <Border Grid.Column="2" Background="#0B0B14">
                <!-- C3StudioGame is added here programmatically in code-behind -->
                <Grid x:Name="ViewportHost">
                    <!-- Fallback shown before the MonoGame control is attached -->
                    <StackPanel x:Name="ViewportPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Opacity="0.3">
                        <TextBlock Text="⚔" FontSize="64"
                                   Foreground="{StaticResource Br.Gold}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="MonoGame Viewport"
                                   Style="{StaticResource SubTitle}"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                        <TextBlock Text="Initialising…"
                                   Style="{StaticResource SectionLabel}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── SPLITTER ──────────────────────────────────────────────── -->
            <GridSplitter Grid.Column="3"
                          Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Br.Border}"
                          ShowsPreview="False"/>

            <!-- ── PROPERTIES PANEL ───────────────────────────────────────── -->
            <Border Grid.Column="4"
                    Background="{StaticResource Br.BgSurface}"
                    BorderBrush="{StaticResource Br.Border}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                    <StackPanel>

                        <!-- Section: Playback -->
                        <TextBlock Text="PLAYBACK"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,0,0,10"/>

                        <!-- Frame info card -->
                        <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Frame" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="{Binding FrameLabel}"
                                           FontFamily="Consolas" FontSize="22"
                                           Foreground="{StaticResource Br.Gold}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- FPS card -->
                        <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,12">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <TextBlock Text="FPS" Style="{StaticResource SectionLabel}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Fps, StringFormat={}{0:0}}"
                                               HorizontalAlignment="Right"
                                               FontFamily="Consolas" FontSize="13"
                                               Foreground="{StaticResource Br.Gold}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Slider Minimum="1" Maximum="60"
                                        Value="{Binding Fps, Mode=TwoWay}"
                                        TickFrequency="5" IsSnapToTickEnabled="False"
                                        Foreground="{StaticResource Br.Gold}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"
                                            HorizontalAlignment="Center">
                                    <Button Content="15" Command="{Binding SetFpsCommand}"
                                            CommandParameter="15"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                                    <Button Content="24" Command="{Binding SetFpsCommand}"
                                            CommandParameter="24"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,3" Margin="0,0,4,0" FontSize="11"/>
                                    <Button Content="30" Command="{Binding SetFpsCommand}"
                                            CommandParameter="30"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,3" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Section: Camera -->
                        <TextBlock Text="CAMERA"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,8,0,10"/>

                        <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Left-drag: orbit"
                                           Style="{StaticResource SectionLabel}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="Scroll / W S: zoom"
                                           Style="{StaticResource SectionLabel}"
                                           Margin="0,0,0,8"/>
                                <Button Content="Reset Camera"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ResetCameraCommand}"
                                        Padding="10,6"/>
                            </StackPanel>
                        </Border>

                        <!-- Section: File -->
                        <TextBlock Text="FILE"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0,8,0,10"/>

                        <Border Style="{StaticResource Card}" Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="Path" Style="{StaticResource SectionLabel}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ModelPath}"
                                           FontFamily="Consolas" FontSize="10"
                                           Foreground="{StaticResource Br.TextDim}"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding ModelPath}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             STATUS BAR
        ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource Br.BgCard}"
                BorderBrush="{StaticResource Br.Border}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{StaticResource Br.TextSecond}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="C3Studio · Phase 2"
                           FontSize="11"
                           Foreground="{StaticResource Br.TextDim}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
