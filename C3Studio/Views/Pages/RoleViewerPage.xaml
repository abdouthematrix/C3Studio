<UserControl
    x:Class="C3Studio.Views.Pages.RoleViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:C3Studio.ViewModels"
    Background="{StaticResource Br.BgDeep}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <!--  Toolbar  -->
            <RowDefinition Height="*" />
            <!--  Main Content  -->
        </Grid.RowDefinitions>

        <!--  ── TOOLBAR ──────────────────────────────────────────────────  -->
        <Border
            Grid.Row="0"
            Background="{StaticResource Br.BgCard}"
            BorderBrush="{StaticResource Br.Border}"
            BorderThickness="0,0,0,1">
            <StackPanel
                Margin="12,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Margin="0,0,20,0"
                    Command="{Binding GoToWorkspaceCommand}"
                    Content="◀ Back"
                    Style="{StaticResource GhostButton}" />

                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Style="{StaticResource SectionLabel}"
                    Text="Base Look:" />
                <ComboBox
                    Width="150"
                    DisplayMemberPath="Value"
                    ItemsSource="{Binding Looks}"
                    SelectedValue="{Binding SelectedLook, Mode=TwoWay}"
                    SelectedValuePath="Key"
                    Style="{StaticResource DarkComboBox}" />

                <Separator Margin="20,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />

                <Button
                    Command="{Binding StepBackCommand}"
                    Content="◀"
                    Style="{StaticResource GhostButton}"
                    ToolTip="Previous Frame" />
                <Button
                    Width="40"
                    Margin="5,0"
                    Command="{Binding PlayPauseCommand}"
                    Content="{Binding PlayPauseLabel}"
                    Style="{StaticResource PrimaryButton}" />
                <Button
                    Command="{Binding StepFwdCommand}"
                    Content="▶"
                    Style="{StaticResource GhostButton}"
                    ToolTip="Next Frame" />
            </StackPanel>
        </Border>

        <!--  ── MAIN CONTENT ────────────────────────────────────────────  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <!--  Sidebar  -->
                <ColumnDefinition Width="4" />
                <!--  Splitter  -->
                <ColumnDefinition Width="*" />
                <!--  Viewport  -->
            </Grid.ColumnDefinitions>

            <!--  ── SIDEBAR: SLOTS & MOTIONS ────────────────────────────  -->
            <Border Grid.Column="0" Background="{StaticResource Br.BgSurface}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">

                        <!--  Equipment Slots Section  -->
                        <TextBlock
                            Margin="0,0,0,12"
                            Style="{StaticResource SectionLabel}"
                            Text="EQUIPMENT SLOTS" />
                        <ItemsControl ItemsSource="{Binding AvailableSockets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,6"
                                        Padding="10"
                                        Background="{StaticResource Br.BgCard}"
                                        BorderBrush="{StaticResource Br.Border}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                Margin="0,0,0,4"
                                                FontSize="11"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource Br.Gold}"
                                                Text="{Binding SocketName}" />

                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <ComboBox
                                                    Grid.Column="0"
                                                    DisplayMemberPath="DisplayName"
                                                    ItemsSource="{Binding AvailableParts}"
                                                    SelectedItem="{Binding SelectedPart, Mode=TwoWay}"
                                                    Style="{StaticResource DarkComboBox}" />

                                                <Button
                                                    Grid.Column="1"
                                                    Margin="4,0,0,0"
                                                    Padding="8,0"
                                                    Command="{Binding ClearCommand}"
                                                    Content="✕"
                                                    Style="{StaticResource GhostButton}"
                                                    ToolTip="Remove" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Motions Section  -->
                        <TextBlock
                            Margin="0,20,0,12"
                            Style="{StaticResource SectionLabel}"
                            Text="AVAILABLE MOTIONS" />
                        <ListBox
                            ItemsSource="{Binding AvailableMotions}"
                            SelectedItem="{Binding SelectedMotion}"
                            Style="{StaticResource NpcListBox}"
                            Visibility="{Binding AvailableMotions.Count, Converter={StaticResource ZeroToCollapsed}}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                        <Border Style="{StaticResource MotionChip}">
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource Br.Gold}"
                                                Text="{Binding Label}" />
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter
                Grid.Column="1"
                Width="4"
                HorizontalAlignment="Stretch"
                Background="{StaticResource Br.Border}" />

            <!--  ── VIEWPORT ────────────────────────────────────────────  -->
            <Border Grid.Column="2" Background="#0B0B14">
                <Grid x:Name="ViewportHost">
                    <StackPanel
                        x:Name="ViewportPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="48"
                            Foreground="{StaticResource Br.Gold}"
                            Text="⚔" />
                        <TextBlock
                            Margin="0,10,0,0"
                            Style="{StaticResource SectionLabel}"
                            Text="Engine Initializing..." />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>